// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------

model User {
  id        Int          @id @default(autoincrement())
  name      String
  email     String       @unique
  password  String
  createdAt DateTime     @default(now())

  // Relationships
  houses    Housemates[] // a user can belong to many houses
  choresCreated Chore[]        @relation("CreatedChores")
  assignedChores  Assignment[]   // chores this user is assigned to
}

model House {
  id         Int          @id @default(autoincrement())
  name       String
  address    String?
  createdAt  DateTime     @default(now())

  // Relationships
  members    Housemates[] // a house can have many members (users)
  chores     Chore[] // a house can have many chores
}

model Housemates {
  id        Int      @id @default(autoincrement())

  // Foreign keys
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  house     House    @relation(fields: [houseId], references: [id])
  houseId   Int

  // Extra info
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  // Prevent duplicate memberships
  @@unique([userId, houseId])
}

model Chore {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  frequency    String
  status       String     @default("Pending")
  dueDate      DateTime
  createdAt    DateTime   @default(now())

  // Foreign keys
  house        House      @relation(fields: [houseId], references: [id])
  houseId      Int

  createdBy    User       @relation("CreatedChores", fields: [createdById], references: [id])
  createdById  Int

  assignedMembers Assignment[]  // users assigned to this chore
}

model Assignment {
  id          Int       @id @default(autoincrement())
  status      String    @default("Pending")
  actionTaken DateTime?

  // Foreign keys
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  chore       Chore     @relation(fields: [choreId], references: [id])
  choreId     Int

  @@unique([userId, choreId]) // prevent duplicate assignments
}



